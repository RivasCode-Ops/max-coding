{
  "name": "max-coding",
  "version": "0.23.0",
  "private": true,
  "description": "Max Stack — auditoria evolutiva local-first de repositórios",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/web"
  ],
  "scripts": {
    "scan": "node packages/repo-scanner/bin/scan.mjs",
    "quick": "node packages/core/bin/run-quick.mjs",
    "deep": "node packages/core/bin/run-audit.mjs",
    "audit": "node packages/core/bin/run-audit.mjs",
    "build:web": "npm run build --workspace=@max-stack/web",
    "prestart": "npm run build:web",
    "start": "node packages/api/bin/serve.mjs",
    "dev:web": "npm run dev --workspace=@max-stack/web",
    "dev:api": "node packages/api/bin/serve.mjs",
    "validar": "node validar.mjs",
    "validate-repo": "node packages/core/bin/validate-repo.mjs",
    "portfolio": "node packages/core/bin/portfolio.mjs",
    "pr-comment": "node packages/core/bin/pr-comment.mjs",
    "watch": "node packages/core/bin/watch.mjs",
    "apply-pilot": "node packages/core/bin/apply-pilot.mjs",
    "verify": "node packages/core/bin/verify.mjs",
    "report": "node packages/core/bin/report.mjs",
    "plan": "node packages/core/bin/plan.mjs",
    "evolve": "node packages/core/bin/evolve.mjs",
    "evolve-batch": "node packages/core/bin/evolve-batch.mjs",
    "watch-portfolio": "node packages/core/bin/watch-portfolio.mjs",
    "portfolio-history": "node packages/core/bin/portfolio-history.mjs",
    "portfolio-digest": "node packages/core/bin/portfolio-digest.mjs",
    "portfolio-heatmap": "node packages/core/bin/portfolio-heatmap.mjs",
    "quality-signals": "node packages/core/bin/quality-signals.mjs",
    "test": "node --test --test-concurrency=1 tests/**/*.test.mjs"
  }
}
