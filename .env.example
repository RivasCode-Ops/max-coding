# Max Stack — GitHub (opcional)

# Personal Access Token (repo + pull_requests)
# GITHUB_TOKEN=ghp_...

# GitHub App (recomendado para PR comments + webhook)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=./max-stack-app.pem
# ou inline: GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Installation ID (ou resolvido automaticamente por repo)
# GITHUB_INSTALLATION_ID=12345678

# Webhook secret (GitHub App → Webhook)
# GITHUB_WEBHOOK_SECRET=your-secret

# Portfolio root padrão
# MAX_PORTFOLIO_ROOT=c:\_PROJETOS
